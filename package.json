{
  "name": "tg_catboxuploader",
  "version": "2.0.0",
  "description": "A simple Telegram bot to upload files to catbox.moe",
  "main": "index.ts",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "start": "npx -y tsx index.ts",
    "build": "tsc && node -e \"const fs=require('fs');fs.mkdirSync('dist/src/i18n',{recursive:true});fs.readdirSync('src/i18n').filter(f=>f.endsWith('.json')).forEach(f=>fs.copyFileSync('src/i18n/'+f,'dist/src/i18n/'+f))\"",
    "serve": "node dist/index.js"
  },
  "keywords": [
    "telegram",
    "bot",
    "catbox"
  ],
  "author": "AnotiaWang",
  "license": "MIT",
  "type": "module",
  "dependencies": {
    "big-integer": "^1.6.52",
    "dotenv": "^16.0.0",
    "mime-types": "^2.1.34",
    "node-catbox": "^3.0.1",
    "pnpm": "^10.32.1",
    "sharp": "^0.34.5",
    "shelljs": "^0.10.0",
    "telegram": "^2.9.8",
    "tsx": "^4.7.0"
  },
  "devDependencies": {
    "@types/mime-types": "^2.1.4",
    "@types/node": "^20.11.5",
    "typescript": "^5.3.3"
  }
}
